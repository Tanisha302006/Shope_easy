NODE_ENV=development
PORT=5000

# Put mongodb://localhost:27017/shopeasy if testing locally. 
# Or an Atlas URI: mongodb+srv://<user>:<pwd>@cluster...
MONGODB_URI=mongodb://localhost:27017/shopeasy

# Required to digitally sign all authentication packets. Keep this string arbitrary and secret payload.
JWT_SECRET=super_secret_shopeasy_token_key_123!
